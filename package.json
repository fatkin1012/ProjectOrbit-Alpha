{
  "name": "toolbox-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Toolbox monorepo with plugin architecture",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev": "npm run dev --workspace=packages/toolbox",
    "build": "npm run build --workspace=packages/toolbox",
    "start": "npm run start --workspace=packages/toolbox",
    "build:all": "npm run build -ws",
    "lint": "eslint"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
