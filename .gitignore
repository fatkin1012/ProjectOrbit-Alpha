# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local toolbox repo importer artifacts
/packages/imported-repos/

# monorepo packages policy:
# ignore all package folders by default, keep only packages/toolbox tracked
/packages/*
!/packages/toolbox/
!/packages/toolbox/**

# keep importer output local-only even inside whitelisted packages/toolbox
/packages/toolbox/public/imported/
/packages/toolbox/public/imported/**
/packages/toolbox/.toolbox-imports.json

# toolbox app cache/build artifacts inside monorepo package
/packages/toolbox/.next/
/packages/toolbox/out/

# nested package dependency/build caches
/packages/**/node_modules/
/packages/**/dist/
/packages/**/.cache/
/packages/**/.turbo/
